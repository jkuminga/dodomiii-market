# Frontend (React + Vite)
# Copy this file to frontend/.env and fill values

# App
VITE_APP_NAME=DODOMIII MARKET
VITE_APP_ENV=development
# In production, set this to the deployed frontend domain.
VITE_APP_URL=http://localhost:5173

# API
# In production, set this to the deployed backend API domain plus /api/v1.
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Supabase (only public values in frontend)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Monitoring (optional)
VITE_SENTRY_DSN=
