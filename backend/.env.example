# Backend (NestJS)
# Copy this file to backend/.env and fill values

# App
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# CORS
# Multiple origins can be provided as comma-separated values.
CORS_ORIGIN=http://localhost:5173
# Trust reverse proxy headers such as X-Forwarded-For.
# Use 1 on Vercel/proxy deployments so req.ip reflects the real client IP.
TRUST_PROXY=

# Database (Supabase Postgres)
# # Runtime query connection (recommended: pooler/session mode)
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# # Migration/direct admin connection (recommended: direct connection)
# DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres


# Session
SESSION_SECRET=replace-with-long-random-secret
SESSION_NAME=admin_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_MAX_AGE_MS=604800000

# Redis / Upstash
# Used for production-safe admin session storage and admin login rate limiting.
# For Upstash, use the Redis-compatible connection URL from the database details.
# Example format: rediss://default:<password>@<host>:6379
REDIS_URL=
# Prefix Redis keys so this app does not collide with other apps in the same Redis DB.
REDIS_KEY_PREFIX=dodomi:
# Enable Redis-backed session store in deployed environments.
# Keep false for local development unless REDIS_URL is configured.
SESSION_REDIS_ENABLED=false
# Enable Redis-backed admin login rate limiting in deployed environments.
# Keep false for local development unless REDIS_URL is configured.
ADMIN_LOGIN_RATE_LIMIT_REDIS_ENABLED=false
# Failed login counter window in seconds.
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
# Maximum failed login attempts from the same IP during the window.
ADMIN_LOGIN_RATE_LIMIT_IP_MAX_ATTEMPTS=20
# Maximum failed login attempts for the same login ID + IP during the window.
ADMIN_LOGIN_RATE_LIMIT_ACCOUNT_IP_MAX_ATTEMPTS=5

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=dodomi

# Orders
ORDER_SHIPPING_FEE=3000
ORDER_DEPOSIT_BANK_NAME=국민은행
ORDER_DEPOSIT_ACCOUNT_HOLDER=도도미마켓
ORDER_DEPOSIT_ACCOUNT_NUMBER=000-00-000000
ORDER_DEPOSIT_DEADLINE_DAYS=1

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Logging/Monitoring
LOG_LEVEL=debug
SENTRY_DSN=

# Notifications
# Keep true when SMS notifications are used.
# SMTP can stay empty if email notifications are not used.
# In production, configure SOLAPI_* credentials unless NOTIFICATIONS_DRY_RUN=true.
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_DRY_RUN=false
NOTIFICATIONS_ADMIN_STATUS_SUMMARY_ENABLED=true
NOTIFICATIONS_RETRY_ATTEMPTS=3
NOTIFICATIONS_RETRY_BASE_DELAY_MS=1000
STORE_WEB_BASE_URL=http://localhost:5173
ADMIN_WEB_BASE_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Dodomi
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_CONNECTION_TIMEOUT_MS=10000

# SMS (Solapi)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# DB Keep-warm (for cold-start mitigation)
DB_KEEP_WARM_ENABLED=true
DB_KEEP_WARM_INTERVAL_MS=600000
